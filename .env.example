# ===== Supabase =====
# ถ้าใช้ Supabase local:  รัน `supabase start` แล้วคัดลอกค่ามาใส่
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# service role key — ใช้ฝั่งเซิร์ฟเวอร์เท่านั้น (LINE webhook) ห้าม expose ให้ browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== LINE Messaging API (MVP 3) =====
# สร้าง Provider + Messaging API channel ที่ https://developers.line.biz
# แล้วนำ Channel access token (long-lived) และ Channel secret มาใส่
# ตั้ง Webhook URL เป็น  https://<โดเมนของคุณ>/api/line/webhook
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Anthropic API (AI อ่านมิเตอร์ MVP 5) — ขอคีย์ที่ console.anthropic.com
ANTHROPIC_API_KEY=

# ===== SMS OTP (เปลี่ยน auth เป็นเบอร์+OTP) =====
# SEND_SMS_HOOK_SECRET = secret ของ Supabase "Send SMS" hook (รูปแบบ v1,whsec_...) — ต้องตรงกับที่ตั้งใน Supabase
SEND_SMS_HOOK_SECRET=
# ผู้ให้บริการ SMS ของคุณ (ปรับ lib/sms.ts ให้ตรง API)
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER=Chao-Dee
